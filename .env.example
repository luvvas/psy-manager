# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psy_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=psy_manager

# API
API_PORT=3001
BETTER_AUTH_URL=http://localhost:3001

# Document storage
# local = grava PDFs em apps/api/.storage durante desenvolvimento
# s3 = usa URLs pre-assinadas para enviar PDFs direto ao bucket privado
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./.storage
AWS_REGION=sa-east-1
AWS_DOCUMENTS_BUCKET=

# Web
VITE_API_URL=http://localhost:3001

# Video call — public URL used to build patient magic links (set to the frontend origin in prod)
PUBLIC_URL=http://localhost:5173

# Video call — TURN server for clients behind strict NAT (optional, falls back to STUN only)
# Run coturn on your EC2 instance and set these values
TURN_URL=turn:your-turn-server:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# Encryption key for patient PII and clinical data at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Google Calendar Integration (OAuth 2.0 Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/google-callback

# Sentry (error monitoring — production only)
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
